# === Auth Option 1: Public API (requires Developer Portal approval) ===
# ECOFLOW_ACCESS_KEY=your_access_key_here
# ECOFLOW_SECRET_KEY=your_secret_key_here

# === Auth Option 2: Private API (your EcoFlow app login) ===
ECOFLOW_EMAIL=your_email@example.com
ECOFLOW_PASSWORD=your_password_here

# Device serial numbers (REQUIRED for Private API, optional for Public API)
# Find these in the EcoFlow app: device settings → serial number
ECOFLOW_DEVICE_SNS=DELTAPRO_SN1,DELTAPRO_SN2,SP_PANEL_SN

# Optional: auto-detected based on auth mode
# ECOFLOW_API_HOST=api.ecoflow.com

# Timezone for Docker (default: UTC)
# TZ=Europe/Kyiv

# === Circuit Names for Smart Home Panel (optional) ===
# 12 comma-separated names matching your breaker layout
# Empty names keep the circuit number only
# CIRCUIT_NAMES=Kitchen,Living,Office,Bedroom,Garage,HVAC,Laundry,Bath,Outdoor,Spare,,

# === Energy Cost Tracking (optional) ===
# ENERGY_RATE=0.12               # Cost per kWh (e.g. 0.12 for $0.12/kWh)
# ENERGY_CURRENCY=$              # Currency symbol ($, €, £, ₴, etc.)

# === Telegram Alerts (optional) ===
# Create a bot via @BotFather, get the token
# Get your chat_id: https://api.telegram.org/bot<TOKEN>/getUpdates
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=123456789

# Alert thresholds (optional, defaults shown)
# ALERT_BATTERY_LOW=20        # SOC % to trigger low battery alert
# ALERT_HIGH_TEMP=45          # °C to trigger high temperature alert
# ALERT_COOLDOWN=1800         # Seconds between repeated alerts (default: 30 min)
# ALERT_GRID_OUTAGE=1         # 1=enabled, 0=disabled
# ALERT_GRID_RESTORE=1
# ALERT_BATTERY_FULL=1
# ALERT_CHARGE_COMPLETE=1
# ALERT_OFFLINE_TIMEOUT=300   # Seconds with no data before offline alert
# ALERT_DAILY_SUMMARY=20      # Hour (0-23) to send daily summary (default: 20 = 8 PM)
# ALERT_MONTHLY_REPORT=1       # 1=send monthly energy/cost report on 1st of month
